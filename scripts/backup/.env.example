# Variables d'environnement pour tests locaux
# ⚠️ NE JAMAIS COMMITER CE FICHIER !

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# URL publique de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

# Clé service role (dans Settings → API)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1...

# URL de connexion PostgreSQL
# ⚠️ IMPORTANT: Utilisez le SESSION POOLER (port 5432) ou Direct connection
# ❌ NE PAS utiliser le Transaction pooler (port 6543)
#
# Supabase propose 3 types de connexion:
#   - Direct connection (db.xxx.supabase.co:5432) - IPv6 - ✅ Compatible pg_dump
#   - Session pooler (aws-x-region.pooler.supabase.com:5432) - IPv4 - ✅ Compatible pg_dump
#   - Transaction pooler (aws-x-region.pooler.supabase.com:6543) - IPv4 - ❌ NON compatible
#
# Pour GitHub Actions, utilisez le SESSION POOLER (IPv4 compatible)
#
# Pour obtenir l'URL correcte:
#   1. Dashboard Supabase → Cliquez "Connect"
#   2. Type: URI, Source: Primary database
#   3. Method: "Session pooler" (recommandé) ou "Direct connection"
#   4. Copiez l'URL avec le port 5432
#
# Format Session pooler (recommandé pour GitHub Actions):
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
#
# Format Direct connection (si IPv6 disponible):
# postgresql://postgres:[PASSWORD]@db.abcdefghijklmnopqrst.supabase.co:5432/postgres
#
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxxx:your-password@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# =============================================================================
# MINIO S3 CONFIGURATION
# =============================================================================

# URL de votre instance Minio (avec https://)
MINIO_ENDPOINT=https://console.s3.dsolution-ia.fr

# Credentials Minio (Access Key et Secret Key)
MINIO_ACCESS_KEY=ton_access_key
MINIO_SECRET_KEY=ton_secret_key

# Nom du bucket où stocker les backups
MINIO_BUCKET=supabase-backups
